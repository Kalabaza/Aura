# Aura Simulator Environment Configuration
# Copy this file to .env and adjust values as needed

# Path to aura/aura.ino file (overrides default relative path)
# Useful when running in Docker or when the aura directory is not a sibling of aura-sim
# Example: AURA_INO_PATH=/path/to/aura/aura.ino
AURA_INO_PATH=

# Enable chokidar polling (recommended for Docker/WSL2)
CHOKIDAR_USEPOLLING=false

# Vite debug settings
# VITE_DEBUG=true
