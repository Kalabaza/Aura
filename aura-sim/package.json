{
  "name": "aura-sim",
  "version": "0.1.0",
  "description": "Real-time simulator for the Aura ESP32 weather widget",
  "type": "module",
  "scripts": {
    "icons:convert": "node scripts/convert-icons.js",
    "prestart": "ts-node src/parser/AuraInoParser.ts",
    "prebuild": "ts-node src/parser/AuraInoParser.ts",
    "start": "concurrently --kill-others-on-fail \"npm run dev\" \"npm run watch:ino\"",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "watch:ino": "ts-node src/watcher/FileWatcher.ts",
    "test:visual": "ts-node tests/visual-test.ts",
    "test:visual:update": "ts-node tests/visual-test.ts --update-refs",
    "test:visual:capture": "ts-node tests/capture-references.ts",
    "package": "bash scripts/package.sh"
  },
  "keywords": [
    "aura",
    "esp32",
    "weather",
    "simulator",
    "cyd",
    "cheap-yellow-display"
  ],
  "author": "Aura Team",
  "license": "GPL-3.0",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "playwright": "^1.40.0",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "chokidar": "^3.5.3",
    "concurrently": "^8.2.0"
  }
}
